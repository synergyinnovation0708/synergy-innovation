NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=

# Optional but recommended: public site URL used in auth recovery emails
NEXT_PUBLIC_APP_URL=https://synergyinnovation.tech

SUPABASE_SERVICE_ROLE_KEY=

SUPABASE_ADMIN_EMAIL=admin@example.com
SUPABASE_ADMIN_PASSWORD=ChangeMe123!
SUPABASE_ADMIN_NAME=System Admin

# Optional: override the table used by /api/employer-inquiries
SUPABASE_EMPLOYER_INQUIRIES_TABLE=employer_inquiries

# Optional: override the table used by /api/job-seeker-inquiries
SUPABASE_JOB_SEEKER_INQUIRIES_TABLE=job_seeker_inquiries

# Optional: override the table used by /api/it-service-inquiries
SUPABASE_IT_SERVICE_INQUIRIES_TABLE=it_service_inquiries

# Optional: override the table used by /api/candidate/profile
SUPABASE_CANDIDATE_PROFILES_TABLE=candidate_profiles

# Optional: override the table used by /api/candidate/job-applications
SUPABASE_CANDIDATE_JOB_APPLICATIONS_TABLE=candidate_job_applications

# Optional: override the table used by /api/admin/job-listings
SUPABASE_JOB_LISTINGS_TABLE=job_listings

# Optional: override the table used by AI usage tracking
SUPABASE_AI_USAGE_EVENTS_TABLE=ai_usage_events

# Cloudinary resume uploads for the job seeker form
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
CLOUDINARY_RESUME_FOLDER=job-seeker-resumes

# OpenAI intake assistant for employer and job seeker autofill
OPENAI_API_KEY=
OPENAI_INTAKE_MODEL=gpt-4.1-mini
OPENAI_SERVICE_CHAT_MODEL=gpt-4.1-mini
OPENAI_SERVICE_CHAT_RATE_LIMIT_MAX=15
OPENAI_SERVICE_CHAT_RATE_LIMIT_WINDOW_MS=600000
OPENAI_SERVICE_CHAT_MAX_INPUT_CHARS=500
OPENAI_SERVICE_CHAT_MAX_HISTORY_MESSAGES=8
OPENAI_SERVICE_CHAT_MAX_TOTAL_CHARS=2400
OPENAI_SERVICE_CHAT_MAX_OUTPUT_TOKENS=450
OPENAI_INTAKE_RATE_LIMIT_MAX=6
OPENAI_INTAKE_RATE_LIMIT_WINDOW_MS=1800000
OPENAI_INTAKE_MAX_MESSAGE_CHARS=4000
OPENAI_INTAKE_MAX_CURRENT_VALUES_CHARS=3000
OPENAI_INTAKE_MAX_OUTPUT_TOKENS=700
